{
  "schemaVersion": 1,
  "id": "bedrockcracker",
  "version": "${version}",
  "name": "BedrockCracker",
  "description": "A mod allows you to easily crack world seed through bedrock patterns.",
  "authors": [
    "MiranCZ",
    "MoRanYue"
  ],
  "contact": {
    "sources": "https://github.com/MoRanYue/BedrockSeedCracker"
  },
  "license": "MIT",
  "icon": "assets/bedrockcracker/icon.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      "me.miran.bedrockcracker.BedrockCracker"
    ]
  },
  "mixins": [
    "bedrockcracker.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "${minecraft_version}",
    "java": ">=25",
    "fabric-api": "*"
  }
}
